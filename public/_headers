# Default — HTML pages, clean-URL routes (e.g. /symposium): always revalidate
/*
  Cache-Control: no-cache, must-revalidate

# Hashed static assets (Next.js _next/) — cache long-term
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Generated PDFs — medium cache, revalidate daily
/*/*.pdf
  Cache-Control: public, max-age=86400, must-revalidate
