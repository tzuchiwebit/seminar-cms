generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-tenancy ──
model Site {
  id        Int      @id @default(autoincrement())
  name      String   // 全球共善學思會
  slug      String   @unique // symposium
  domain    String?  // symposium.tzuchi.org
  logo      String?
  status    String   @default("draft") // draft, published, archived
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  speakers      Speaker[]
  days          Day[]
  venues        Venue[]
  exhibitions   Exhibition[]
  registrations Registration[]
  uploads       Upload[]
  settings      SiteSetting[]

  @@map("sites")
}

// ── Speakers ──
model Speaker {
  id          Int      @id @default(autoincrement())
  siteId      Int      @map("site_id")
  name        String   // 汪悅進
  nameEn      String?  @map("name_en") // Eugene Wang
  affiliation String?  // Harvard University
  title       String?  // Professor, CAMLab Director
  bio         String?
  photo       String?
  status      String   @default("draft") // draft, confirmed, pending
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site             Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sessionSpeakers  SessionSpeaker[]
  papers           Paper[]

  @@map("speakers")
}

// ── Programme Days ──
model Day {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  dayNumber Int      @map("day_number") // 1, 2, 3
  date      DateTime // 2026-05-07
  titleZh   String   @map("title_zh") // 應用佛教與菩薩道
  titleEn   String?  @map("title_en") // Applied Buddhism and the Bodhisattva Path
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@unique([siteId, dayNumber])
  @@map("days")
}

// ── Sessions (within a day) ──
model Session {
  id          Int      @id @default(autoincrement())
  dayId       Int      @map("day_id")
  type        String   // opening, keynote, paper_session, roundtable, dinner, break
  titleZh     String   @map("title_zh") // 開幕典禮
  titleEn     String?  @map("title_en") // Opening Ceremony
  subtitleZh  String?  @map("subtitle_zh")
  subtitleEn  String?  @map("subtitle_en")
  startTime   String   @map("start_time") // "08:30"
  duration    Int?     // minutes
  venue       String?
  capacity    Int?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  day             Day              @relation(fields: [dayId], references: [id], onDelete: Cascade)
  sessionSpeakers SessionSpeaker[]
  papers          Paper[]

  @@map("sessions")
}

// ── Session ↔ Speaker (many-to-many) ──
model SessionSpeaker {
  id        Int    @id @default(autoincrement())
  sessionId Int    @map("session_id")
  speakerId Int    @map("speaker_id")
  role      String @default("speaker") // speaker, moderator, discussant

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, speakerId])
  @@map("session_speakers")
}

// ── Papers ──
model Paper {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  speakerId   Int?     @map("speaker_id")
  titleZh     String   @map("title_zh") // 〈人間佛教的菩薩行與社會參與〉
  titleEn     String?  @map("title_en")
  abstract    String?
  status      String   @default("draft") // draft, submitted, accepted
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  @@map("papers")
}

// ── Venues ──
model Venue {
  id          Int      @id @default(autoincrement())
  siteId      Int      @map("site_id")
  name        String   // Student Organization Center at Hilles (SOCH)
  nameZh      String?  @map("name_zh") // 哈佛大學學生社團中心
  description String?
  address     String?
  type        String   @default("main") // main, evening, exhibition
  capacity    Int?
  image       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("venues")
}

// ── Exhibition ──
model Exhibition {
  id          Int      @id @default(autoincrement())
  siteId      Int      @map("site_id")
  titleZh     String   @map("title_zh") // 明心
  titleEn     String?  @map("title_en") // Journey to Enlightenment
  description String?
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  venue       String?
  image       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("exhibitions")
}

// ── Registrations ──
model Registration {
  id        Int      @id @default(autoincrement())
  siteId    Int      @map("site_id")
  name      String
  email     String
  phone     String?
  org       String?  // organization
  status    String   @default("pending") // pending, confirmed, cancelled
  createdAt DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("registrations")
}

// ── Uploads ──
model Upload {
  id           Int      @id @default(autoincrement())
  siteId       Int      @map("site_id")
  filename     String   // uuid.webp
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int      // bytes
  path         String   // /uploads/1/speakers/uuid.webp
  category     String   @default("general") // speakers, gallery, general
  createdAt    DateTime @default(now()) @map("created_at")

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("uploads")
}

// ── Site Settings ──
model SiteSetting {
  id    Int    @id @default(autoincrement())
  siteId Int   @map("site_id")
  key   String
  value String

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, key])
  @@map("site_settings")
}

// ── Auth.js tables ──
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      AuthSession[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
