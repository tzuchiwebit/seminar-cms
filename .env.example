NEXT_PUBLIC_POCKETBASE_URL=https://academic-events.pockethost.io/

# --- Drust (experimental; see scripts/drust-mirror-all.mjs) ---
# Backend selector (default: pb). Set to `drust` in .env.local to test Drust locally.
NEXT_PUBLIC_DB_BACKEND=pb
# Drust REST base URL (tenant-scoped). Only used when backend = drust.
DRUST_BASE_URL=https://tool.tzuchi-org.tw/drust/t/35d6eba3-a0b7-4f09-9a54-7855fdb417f1
# Drust admin token. SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_.
# Token is held by the /api/drust proxy so the browser never sees it.
DRUST_TOKEN=
